<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BgBrush" Color="#FFF7F8FB" />
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="#FFF1F3F8" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFE8ECF5" />
    <SolidColorBrush x:Key="BorderBrush" Color="#FFD8DFEC" />
    <SolidColorBrush x:Key="BorderBrightBrush" Color="#FFC8D3E8" />
    <SolidColorBrush x:Key="FgBrush" Color="#FF202530" />
    <SolidColorBrush x:Key="FgMutedBrush" Color="#FF4F617A" />
    <SolidColorBrush x:Key="FgDimBrush" Color="#FF7B8AA0" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF007A66" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF00917A" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FFC93030" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFCC8A00" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF007A66" />
    <SolidColorBrush x:Key="PurpleBrush" Color="#FF7F5AD0" />
    <SolidColorBrush x:Key="BlueBrush" Color="#FF2A6FD2" />
    <SolidColorBrush x:Key="PinkBrush" Color="#FFB6457B" />
    <SolidColorBrush x:Key="OrangeBrush" Color="#FFC66A1A" />

    <SolidColorBrush x:Key="AccentDimBrush" Color="#22007A66" />
    <SolidColorBrush x:Key="DangerDimBrush" Color="#22C93030" />
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent" />

    <x:Double x:Key="HeaderFontSize">18</x:Double>
    <x:Double x:Key="BodyFontSize">14</x:Double>
    <x:Double x:Key="SmallFontSize">12</x:Double>
    <x:Double x:Key="TinyFontSize">10</x:Double>
    <x:Double x:Key="SectionHeaderFontSize">11</x:Double>

    <Thickness x:Key="SidebarPadding">12,8</Thickness>
    <Thickness x:Key="ChannelItemPadding">10,8</Thickness>
    <Thickness x:Key="MessagePadding">16,4</Thickness>
    <CornerRadius x:Key="SmallRadius">4</CornerRadius>
    <CornerRadius x:Key="MediumRadius">8</CornerRadius>
    <CornerRadius x:Key="LargeRadius">12</CornerRadius>
    <CornerRadius x:Key="CircleRadius">999</CornerRadius>

</ResourceDictionary>
