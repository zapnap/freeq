<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="#FF0C0C0F" />
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="#FF131318" />
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="#FF1C1C24" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF26263A" />
    <SolidColorBrush x:Key="BorderBrush" Color="#FF1E1E2E" />
    <SolidColorBrush x:Key="BorderBrightBrush" Color="#FF2A2A3E" />
    <SolidColorBrush x:Key="FgBrush" Color="#FFE8E8ED" />
    <SolidColorBrush x:Key="FgMutedBrush" Color="#FF9898B0" />
    <SolidColorBrush x:Key="FgDimBrush" Color="#FF555570" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF00D4AA" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF00F0C0" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FFFF5C5C" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFFFB547" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF00D4AA" />
    <SolidColorBrush x:Key="PurpleBrush" Color="#FFB18CFF" />
    <SolidColorBrush x:Key="BlueBrush" Color="#FF5C9EFF" />
    <SolidColorBrush x:Key="PinkBrush" Color="#FFFF6EB4" />
    <SolidColorBrush x:Key="OrangeBrush" Color="#FFFF9547" />

    <!-- Accent dim (20% opacity) -->
    <SolidColorBrush x:Key="AccentDimBrush" Color="#3300D4AA" />
    <SolidColorBrush x:Key="DangerDimBrush" Color="#33FF5C5C" />

    <!-- Transparent for hover states -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent" />

    <!-- Typography -->
    <x:Double x:Key="HeaderFontSize">18</x:Double>
    <x:Double x:Key="BodyFontSize">14</x:Double>
    <x:Double x:Key="SmallFontSize">12</x:Double>
    <x:Double x:Key="TinyFontSize">10</x:Double>
    <x:Double x:Key="SectionHeaderFontSize">11</x:Double>

    <!-- Spacing -->
    <Thickness x:Key="SidebarPadding">12,8</Thickness>
    <Thickness x:Key="ChannelItemPadding">10,8</Thickness>
    <Thickness x:Key="MessagePadding">16,4</Thickness>
    <CornerRadius x:Key="SmallRadius">4</CornerRadius>
    <CornerRadius x:Key="MediumRadius">8</CornerRadius>
    <CornerRadius x:Key="LargeRadius">12</CornerRadius>
    <CornerRadius x:Key="CircleRadius">999</CornerRadius>

</ResourceDictionary>
