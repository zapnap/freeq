<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Freeq.WinUI.Controls.ConnectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BgBrush}">
        <!-- Decorative background gradients -->
        <Ellipse Width="400" Height="400" Opacity="0.08"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-100,-100,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="300" Height="300" Opacity="0.06"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-80,-80">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="{StaticResource PurpleColor}" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Centered card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource BgSecondaryBrush}"
                CornerRadius="16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Width="440" Padding="32,28">
            <StackPanel Spacing="20">

                <!-- Logo + Branding -->
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <Border Width="40" Height="40" CornerRadius="10"
                                Background="{StaticResource AccentDimBrush}">
                            <TextBlock Text="f" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="free" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="q" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource FgBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Identity-native IRC with cryptographic signing"
                               FontSize="12" Foreground="{StaticResource FgDimBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center" />

                    <!-- Feature badges -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12"
                                Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="&#x2713;" FontSize="11" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Signed messages" FontSize="11"
                                       Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="&#x1F512;" FontSize="10" VerticalAlignment="Center" />
                            <TextBlock Text="E2EE DMs" FontSize="11"
                                       Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="&#x1F98B;" FontSize="10" VerticalAlignment="Center" />
                            <TextBlock Text="Bluesky identity" FontSize="11"
                                       Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Mode Tabs -->
                <Grid CornerRadius="8" Background="{StaticResource BgTertiaryBrush}" Padding="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="AtProtoTab"
                            Content="AT Protocol" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="13" FontWeight="SemiBold"
                            Padding="0,8" MinHeight="0"
                            CornerRadius="6"
                            Click="OnAtProtoTabClick" />
                    <Button Grid.Column="1" x:Name="GuestTab"
                            Content="Guest" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="13" FontWeight="SemiBold"
                            Padding="0,8" MinHeight="0"
                            CornerRadius="6"
                            Click="OnGuestTabClick" />
                </Grid>

                <!-- AT Protocol fields -->
                <StackPanel x:Name="AtProtoFields" Spacing="14">
                    <StackPanel Spacing="5">
                        <TextBlock Text="AT PROTOCOL HANDLE" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource FgDimBrush}" CharacterSpacing="80" />
                        <TextBox x:Name="HandleInput"
                                 PlaceholderText="you.bsky.social"
                                 FontSize="14"
                                 Background="{StaticResource BgBrush}"
                                 Foreground="{StaticResource FgBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 CornerRadius="8"
                                 Padding="14,11"
                                 TextChanged="OnHandleChanged"
                                 KeyDown="OnFieldKeyDown" />
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="NICKNAME (OPTIONAL)" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource FgDimBrush}" CharacterSpacing="80" />
                        <TextBox x:Name="AtNickInput"
                                 PlaceholderText="Derived from handle"
                                 FontSize="14"
                                 Background="{StaticResource BgBrush}"
                                 Foreground="{StaticResource FgBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 CornerRadius="8"
                                 Padding="14,11"
                                 TextChanged="OnAtNickChanged" />
                    </StackPanel>
                </StackPanel>

                <!-- Guest fields -->
                <StackPanel x:Name="GuestFields" Spacing="14" Visibility="Collapsed">
                    <StackPanel Spacing="5">
                        <TextBlock Text="NICKNAME" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource FgDimBrush}" CharacterSpacing="80" />
                        <TextBox x:Name="GuestNickInput"
                                 FontSize="14"
                                 Background="{StaticResource BgBrush}"
                                 Foreground="{StaticResource FgBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 CornerRadius="8"
                                 Padding="14,11"
                                 KeyDown="OnFieldKeyDown" />
                    </StackPanel>
                </StackPanel>

                <!-- Channels (both modes) -->
                <StackPanel Spacing="5">
                    <TextBlock Text="AUTO-JOIN CHANNELS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource FgDimBrush}" CharacterSpacing="80" />
                    <TextBox x:Name="ChannelInput"
                             Text="#freeq"
                             FontSize="14"
                             Background="{StaticResource BgBrush}"
                             Foreground="{StaticResource FgBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             CornerRadius="8"
                             Padding="14,11"
                             KeyDown="OnFieldKeyDown" />
                </StackPanel>

                <!-- Advanced settings toggle -->
                <Button x:Name="AdvancedToggle" Background="Transparent"
                        Foreground="{StaticResource FgDimBrush}"
                        FontSize="12" Padding="0" MinWidth="0" MinHeight="0"
                        HorizontalAlignment="Left"
                        Click="OnAdvancedToggle">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock x:Name="AdvancedArrow" Text="&#xE76C;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Advanced settings" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel x:Name="AdvancedFields" Spacing="14" Visibility="Collapsed">
                    <StackPanel Spacing="5">
                        <TextBlock Text="WEBSOCKET URL" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource FgDimBrush}" CharacterSpacing="80" />
                        <TextBox x:Name="ServerInput"
                                 Text="wss://irc.freeq.at/irc"
                                 FontSize="14"
                                 Background="{StaticResource BgBrush}"
                                 Foreground="{StaticResource FgBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 CornerRadius="8"
                                 Padding="14,11" />
                    </StackPanel>
                </StackPanel>

                <!-- Error message -->
                <Border x:Name="ErrorBox" Visibility="Collapsed"
                        Background="{StaticResource DangerDimBrush}"
                        CornerRadius="8" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource DangerBrush}" VerticalAlignment="Top"
                                   Margin="0,2,0,0" />
                        <TextBlock x:Name="ErrorText" FontSize="13"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Connect button -->
                <Button x:Name="ConnectButton" HorizontalAlignment="Stretch"
                        Background="{StaticResource AccentBrush}"
                        Foreground="#FF0C0C0F"
                        FontWeight="Bold" FontSize="14"
                        Padding="0,13"
                        CornerRadius="8"
                        Click="OnConnectClick"
                        HorizontalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing x:Name="ConnectSpinner" IsActive="False"
                                      Width="16" Height="16" Visibility="Collapsed"
                                      Foreground="#FF0C0C0F" />
                        <TextBlock x:Name="ConnectButtonText" Text="Sign in with AT Protocol" />
                    </StackPanel>
                </Button>

                <!-- Footer links -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                    <HyperlinkButton Content="freeq.at" FontSize="11"
                                     Foreground="{StaticResource FgDimBrush}"
                                     Padding="0" MinWidth="0" MinHeight="0"
                                     NavigateUri="https://freeq.at" />
                    <TextBlock Text="·" FontSize="11" Foreground="{StaticResource FgDimBrush}"
                               VerticalAlignment="Center" />
                    <HyperlinkButton Content="GitHub" FontSize="11"
                                     Foreground="{StaticResource FgDimBrush}"
                                     Padding="0" MinWidth="0" MinHeight="0"
                                     NavigateUri="https://github.com/chad/freeq" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
