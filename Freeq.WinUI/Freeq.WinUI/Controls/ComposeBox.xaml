<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Freeq.WinUI.Controls.ComposeBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BgSecondaryBrush}"
          BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
          Padding="16,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Message input -->
        <TextBox Grid.Column="0" x:Name="MessageInput"
                 PlaceholderText="Message #channel"
                 AcceptsReturn="False"
                 FontSize="{StaticResource BodyFontSize}"
                 Background="{StaticResource BgTertiaryBrush}"
                 Foreground="{StaticResource FgBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 BorderThickness="1"
                 CornerRadius="{StaticResource MediumRadius}"
                 Padding="12,10"
                 KeyDown="OnInputKeyDown" />

        <!-- Send button -->
        <Button Grid.Column="1" x:Name="SendButton"
                Margin="8,0,0,0" Padding="12,10"
                CornerRadius="{StaticResource MediumRadius}"
                MinWidth="0" MinHeight="0"
                Background="{StaticResource AccentBrush}"
                Foreground="#FF0C0C0F"
                FontWeight="Bold" FontSize="14"
                Click="OnSendClick"
                VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
