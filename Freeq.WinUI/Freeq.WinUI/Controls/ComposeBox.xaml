<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Freeq.WinUI.Controls.ComposeBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BgSecondaryBrush}"
          BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Typing indicator: "Alice is typing…" — hidden when empty -->
        <TextBlock Grid.Row="0" x:Name="TypingIndicator"
                   Margin="16,6,16,0"
                   FontSize="{StaticResource TinyFontSize}"
                   Foreground="{StaticResource FgDimBrush}"
                   FontStyle="Italic"
                   Visibility="Collapsed" />

        <!-- Edit mode bar: shown when editing an existing message -->
        <Grid Grid.Row="1" x:Name="EditBar"
              Background="{StaticResource BgTertiaryBrush}"
              Padding="16,6"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                <TextBlock x:Name="EditBarLabel" Text="Editing message"
                           FontSize="{StaticResource TinyFontSize}"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Button Grid.Column="1" x:Name="CancelEditButton"
                    Background="Transparent" BorderThickness="0"
                    Padding="4,2" MinWidth="0" MinHeight="0"
                    Click="OnCancelEditClick">
                <TextBlock Text="Cancel" FontSize="{StaticResource TinyFontSize}"
                           Foreground="{StaticResource FgMutedBrush}" />
            </Button>
        </Grid>

        <!-- Compose formatting toolbar -->
        <Grid Grid.Row="2" Padding="16,8,16,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button x:Name="BoldButton" Content="B" FontWeight="Bold" Padding="8,2" Click="OnBoldClick" />
                <Button x:Name="ItalicButton" Content="I" FontStyle="Italic" Padding="8,2" Click="OnItalicClick" />
                <Button x:Name="CodeButton" Content="&lt;/&gt;" Padding="8,2" Click="OnCodeClick" />
                <Button x:Name="LinkButton" Content="Link" Padding="8,2" Click="OnLinkClick" />
            </StackPanel>
        </Grid>

        <!-- Compose row: input + actions + send button -->
        <Grid Grid.Row="3" Padding="16,8,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Autocomplete popup anchored to the input -->
                 <Popup x:Name="AutocompletePopup">
                <Border Background="{StaticResource BgTertiaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource MediumRadius}"
                        Padding="4">
                    <ListView x:Name="AutocompleteList"
                              SelectionMode="Single"
                              MaxHeight="160"
                              ItemContainerStyle="{StaticResource DefaultListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="{StaticResource BodyFontSize}"
                                           Foreground="{StaticResource FgBrush}"
                                           Padding="8,4" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Popup>

            <!-- Message input -->
            <TextBox Grid.Column="0" x:Name="MessageInput"
                     PlaceholderText="Message #channel"
                     AcceptsReturn="True"
                     AllowDrop="True"
                     MaxHeight="120"
                     TextWrapping="Wrap"
                     FontSize="{StaticResource BodyFontSize}"
                     Background="{StaticResource BgTertiaryBrush}"
                     Foreground="{StaticResource FgBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     BorderThickness="1"
                     CornerRadius="{StaticResource MediumRadius}"
                     Padding="12,10"
                     KeyDown="OnInputKeyDown"
                         TextChanged="OnInputTextChanged"
                         Paste="OnInputPaste"
                         DragOver="OnInputDragOver"
                         DragLeave="OnInputDragLeave"
                         Drop="OnInputDrop" />

                    <Button Grid.Column="1" x:Name="AttachButton"
                        Margin="8,0,0,0" Padding="10,10"
                        CornerRadius="{StaticResource MediumRadius}"
                        MinWidth="0" MinHeight="0"
                        Background="{StaticResource BgTertiaryBrush}"
                        Foreground="{StaticResource FgBrush}"
                        Click="OnAttachClick"
                        VerticalAlignment="Bottom"
                        ToolTipService.ToolTip="Attach file">
                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           VerticalAlignment="Center" />
                    </Button>

            <!-- Send button -->
                    <Button Grid.Column="2" x:Name="SendButton"
                    Margin="8,0,0,0" Padding="12,10"
                    CornerRadius="{StaticResource MediumRadius}"
                    MinWidth="0" MinHeight="0"
                    Background="{StaticResource AccentBrush}"
                    Foreground="#FF0C0C0F"
                    FontWeight="Bold" FontSize="14"
                    Click="OnSendClick"
                    VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
