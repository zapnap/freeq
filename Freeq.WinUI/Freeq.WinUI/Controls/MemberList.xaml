<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Freeq.WinUI.Controls.MemberList"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Freeq.WinUI.Controls"
    xmlns:models="using:Freeq.WinUI.Models">

    <Grid Background="{StaticResource BgSecondaryBrush}" Width="208"
          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12">
            <StackPanel>

                <!-- Operators Section -->
                <StackPanel x:Name="OpsSection" Visibility="Collapsed">
                    <TextBlock x:Name="OpsHeader" FontSize="{StaticResource SectionHeaderFontSize}"
                               FontWeight="Bold" Foreground="{StaticResource FgDimBrush}"
                               Padding="8,4,8,6" CharacterSpacing="120" />
                    <ListView x:Name="OpsList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnMemberClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MemberModel">
                                <Grid Padding="8,5" Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Mini Avatar: nick-colored -->
                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{x:Bind AvatarBackgroundBrush}">
                                            <TextBlock Text="{x:Bind NickInitial}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{x:Bind NickBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <!-- Online dot -->
                                        <Ellipse Width="10" Height="10"
                                                 Fill="{StaticResource SuccessBrush}"
                                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                 Stroke="{StaticResource BgSecondaryBrush}" StrokeThickness="2" />
                                    </Grid>

                                    <!-- Role badge -->
                                    <TextBlock Grid.Column="1" Text="{x:Bind RoleBadge}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource SuccessBrush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />

                                    <!-- Nick: hash-colored -->
                                    <TextBlock Grid.Column="2" Text="{x:Bind Nick}"
                                               FontSize="{StaticResource BodyFontSize}"
                                               Foreground="{x:Bind NickBrush}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="away" FontSize="10" Foreground="{StaticResource WarningBrush}"
                                                   Visibility="{x:Bind local:MemberList.AwayToVisibility(Status)}" />
                                    <!-- Verified: teal circle badge -->
                                    <Border
                                            Width="16" Height="16" CornerRadius="8"
                                            Background="{StaticResource AccentDimBrush}"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind local:MemberList.BoolToVis(IsVerified)}">
                                        <TextBlock Text="&#x2713;" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Voiced Section -->
                <StackPanel x:Name="VoicedSection" Visibility="Collapsed" Margin="0,8,0,0">
                    <TextBlock x:Name="VoicedHeader" FontSize="{StaticResource SectionHeaderFontSize}"
                               FontWeight="Bold" Foreground="{StaticResource FgDimBrush}"
                               Padding="8,4,8,6" CharacterSpacing="120" />
                    <ListView x:Name="VoicedList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnMemberClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MemberModel">
                                <Grid Padding="8,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{x:Bind AvatarBackgroundBrush}">
                                            <TextBlock Text="{x:Bind NickInitial}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{x:Bind NickBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Ellipse Width="10" Height="10"
                                                 Fill="{StaticResource SuccessBrush}"
                                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                 Stroke="{StaticResource BgSecondaryBrush}" StrokeThickness="2" />
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Bind RoleBadge}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind Nick}"
                                               FontSize="{StaticResource BodyFontSize}"
                                               Foreground="{x:Bind NickBrush}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="away" FontSize="10" Foreground="{StaticResource WarningBrush}"
                                               Visibility="{x:Bind local:MemberList.AwayToVisibility(Status)}" />
                                    <Border
                                            Width="16" Height="16" CornerRadius="8"
                                            Background="{StaticResource AccentDimBrush}"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind local:MemberList.BoolToVis(IsVerified)}">
                                        <TextBlock Text="&#x2713;" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Members Section -->
                <StackPanel x:Name="MembersSection" Margin="0,8,0,0">
                    <TextBlock x:Name="MembersHeader" FontSize="{StaticResource SectionHeaderFontSize}"
                               FontWeight="Bold" Foreground="{StaticResource FgDimBrush}"
                               Padding="8,4,8,6" CharacterSpacing="120" />
                    <ListView x:Name="MembersList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnMemberClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MemberModel">
                                <Grid Padding="8,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{x:Bind AvatarBackgroundBrush}">
                                            <TextBlock Text="{x:Bind NickInitial}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{x:Bind NickBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Ellipse Width="10" Height="10"
                                                 Fill="{StaticResource SuccessBrush}"
                                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                 Stroke="{StaticResource BgSecondaryBrush}" StrokeThickness="2" />
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Nick}"
                                               FontSize="{StaticResource BodyFontSize}"
                                               Foreground="{x:Bind NickBrush}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="away" FontSize="10" Foreground="{StaticResource WarningBrush}"
                                               Visibility="{x:Bind local:MemberList.AwayToVisibility(Status)}" />
                                    <Border
                                            Width="16" Height="16" CornerRadius="8"
                                            Background="{StaticResource AccentDimBrush}"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind local:MemberList.BoolToVis(IsVerified)}">
                                        <TextBlock Text="&#x2713;" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
