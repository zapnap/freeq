<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Freeq.WinUI.Controls.TopBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BgSecondaryBrush}" Height="56"
          BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
          Padding="16,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Channel icon -->
        <TextBlock Grid.Column="0" x:Name="ChannelIcon" Text="#" FontSize="18"
                   Foreground="{StaticResource FgDimBrush}" FontWeight="Bold"
                   VerticalAlignment="Center" Margin="0,0,8,0" />

        <!-- Channel name -->
        <TextBlock Grid.Column="1" x:Name="ChannelName" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource FgBrush}" VerticalAlignment="Center" />

        <!-- Divider -->
        <Border Grid.Column="2" Width="1" Height="20" Margin="12,0"
                Background="{StaticResource BorderBrush}" VerticalAlignment="Center" />

        <!-- Topic -->
        <TextBlock Grid.Column="3" x:Name="TopicText" FontSize="{StaticResource SmallFontSize}"
                   Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />

        <!-- Member count -->
        <Button Grid.Column="4" x:Name="MemberCountButton"
                Background="Transparent" Foreground="{StaticResource FgDimBrush}"
                Padding="8,4" MinWidth="0" MinHeight="0"
                VerticalAlignment="Center" Click="OnMemberToggleClick">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="MemberCountText" FontSize="{StaticResource SmallFontSize}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <!-- Settings gear -->
        <Button Grid.Column="5" Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                FontSize="14" Background="Transparent"
                Foreground="{StaticResource FgDimBrush}"
                Padding="8,4" MinWidth="0" MinHeight="0"
                VerticalAlignment="Center" />
    </Grid>
</UserControl>
